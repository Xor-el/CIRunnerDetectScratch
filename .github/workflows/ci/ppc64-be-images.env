# Pinned images for linux-powerpc64-be CI (source from ppc64-qemu-setup.sh / ppc64-be-build.sh).
PPC64_QEMU_VERSION=7.2.0-1
# Full image with register script + all qemu-user-static binaries (host binfmt setup).
PPC64_QEMU_REGISTER_IMAGE=multiarch/qemu-user-static:${PPC64_QEMU_VERSION}
# Arch-specific image for COPY into the ppc64 runtime container.
PPC64_QEMU_IMAGE=multiarch/qemu-user-static:x86_64-ppc64-${PPC64_QEMU_VERSION}
PPC64_BASE_IMAGE=urbanogilson/debian-debootstrap-ports:ppc64-forky-sid
PPC64_CI_IMAGE=cirunner-ppc64-be:ci
